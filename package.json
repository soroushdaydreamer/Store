{
  "name": "sinanoor-store-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:functions",
    "build:functions": "esbuild functions/api/*.ts --bundle --platform=neutral --target=es2022 --format=esm --outdir=dist/functions/api --external:cloudflare:*",
    "build:only": "tsc -b && vite build",
    "server": "tsx server.ts",
    "server:dev": "tsx watch server.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "check": "tsc -b",
    "deploy": "wrangler pages deploy dist",
    "deploy:init": "wrangler pages project create sinanoor-store"
  },
